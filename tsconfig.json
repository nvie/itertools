{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "~": ["./src"],
      "~/*": ["./src/*"]
    },

    // NOTE Only temporarily needed, until https://github.com/egoist/tsup/pull/1390 gets merged
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "test"]
}
